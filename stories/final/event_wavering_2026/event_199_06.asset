    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(The frilliness isn't quite what I thought it would be... Maybe the skirt lacks volume?)",
