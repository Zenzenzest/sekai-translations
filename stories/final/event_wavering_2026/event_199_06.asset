        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 272
        }
      ],
      "WindowDisplayName": "Mizuki's Sister's Message",
      "Body": "'I'll recommend some books that might be helpful for this. They might be a bit difficult for you, though...'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
