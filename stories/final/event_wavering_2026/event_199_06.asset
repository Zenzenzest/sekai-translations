    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(Make sure the weight of the fabric doesn't look like it's flowing downward too much. Don't draw it like it's on a dress form, but imagine it hanging on a hanger...)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
