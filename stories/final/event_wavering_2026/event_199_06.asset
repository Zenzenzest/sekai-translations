          "VoiceId": "voice_ev_night_25_06_45_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 296
        }
      ],
      "WindowDisplayName": "Ena",
      "Body": "Well, you would end up having to take remedial classes, after all.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 296,
          "MotionName": "w-cute12-tilthead",
