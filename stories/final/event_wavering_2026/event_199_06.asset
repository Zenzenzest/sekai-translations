    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "...Alright. That should be all the patterns done, I think.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-happy14-nod",
          "FacialName": "face_smile_01",
