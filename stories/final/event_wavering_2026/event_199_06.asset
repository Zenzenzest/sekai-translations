      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "Yeah, I'll be careful. Thanks, Ena!",
      "TalkTention": 0,
      "LipSync": 1,
