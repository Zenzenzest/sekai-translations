    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 272
        }
      ],
      "WindowDisplayName": "Mizuki's Sister's Message",
      "Body": "'I think it's cute, but have you thought about what happens when you translate this into an actual piece of clothing?'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 272,
          "VoiceId": "voice_ev_night_25_06_08_140",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "Eh? An actual piece...",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-cool02-tilthead",
          "FacialName": "face_smallmouth_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_06_09_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(Unlike with the collage, I thought I was being mindful of that this time...)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-cute02-tilthead",
          "FacialName": "face_worry_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_06_10_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 272
        }
      ],
      "WindowDisplayName": "Mizuki's Sister's Message",
      "Body": "'For example, the ribbons by the frills look like they're floating. How do you plan to actually attach them?'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 272,
          "VoiceId": "voice_ev_night_25_06_11_140",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "Ah...! Now that she mentions it, it does look hard to attach them there...",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-normal08-tilthead",
