    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 272
        }
      ],
      "WindowDisplayName": "Mizuki's Sister's Message",
      "Body": "'I saw the photos. Yeah—'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 272,
          "VoiceId": "voice_ev_night_25_06_65_140",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 272
        }
      ],
      "WindowDisplayName": "Mizuki's Sister's Message",
      "Body": "'The pattern you used has a straight silhouette, so if you want to go for a fluffy princess line, I think you need to modify the pattern a bit more.'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 272,
          "VoiceId": "voice_ev_night_25_06_66_140",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "Ah... I see. Then I have to remake it keeping the spread in mind...",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-adult01-nod",
