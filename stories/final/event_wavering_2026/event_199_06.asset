    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(—Alright, this cut is done. We'll need some new materials for the next cut, so I should let Ena know.)",
