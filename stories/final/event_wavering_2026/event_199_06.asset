          "VoiceId": "voice_ev_night_25_06_13_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 272
        }
      ],
      "WindowDisplayName": "Mizuki's Sister's Message",
      "Body": "'It might not look unnatural on a fashion illustration, but you should try designing while keeping in mind how it will actually be sewn together to some extent.'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 272,
          "VoiceId": "voice_ev_night_25_06_14_140",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 272
        }
      ],
      "WindowDisplayName": "Mizuki's Sister's Message",
      "Body": "'If you leave it like this, you're going to have a hard time when you make the hanger illustration.'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 272,
          "VoiceId": "voice_ev_night_25_06_15_140",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(A hanger illustration—a drawing of the clothes as if they were hanging on a hanger, used for making patterns and spec sheets, right?)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-normal15-shy",
          "FacialName": "face_smallmouth_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
