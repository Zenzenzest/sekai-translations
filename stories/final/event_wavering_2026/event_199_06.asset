      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "...But I've only just started. Let's try again!",
      "TalkTention": 0,
