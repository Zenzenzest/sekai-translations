    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Yoshino",
      "Body": "...Because I was like that...?",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_04_46_1085",
