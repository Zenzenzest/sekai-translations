      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Yoshino",
      "Body": "...Well, maybe you're right.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_04_75_1085",
