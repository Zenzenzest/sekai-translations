    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "'Then, I'll need the girl's profile, different hand poses, her smiling face for the end, and also—'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-cool02-tilthead",
          "FacialName": "face_smile_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_01_60_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 296
        }
      ],
      "WindowDisplayName": "Ena",
      "Body": "'Hey! Don't just suddenly start asking for everything with zero hesitation!'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 296,
          "MotionName": "w-cute13-forward",
          "FacialName": "face_angry_02",
