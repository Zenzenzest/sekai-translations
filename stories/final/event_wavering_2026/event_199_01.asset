        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 1,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "...It definitely seems like Kanade's been struggling a bit.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
