  "TalkData": [
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(Hmm... I guess this song really does feel a bit like our early stuff.)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-cool06-blushed",
          "FacialName": "face_smallmouth_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_01_01_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(If that's the case, maybe I should put in an homage to those days for the MV. We talked about keeping the animation minimal this time to focus on the worldbuilding, revealing the whole illustration right at the chorus—)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-cool02-tilthead",
          "FacialName": "face_smile_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_01_02_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 1,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(...Yeah, let's go with this.)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-cute02-nodB",
          "FacialName": "face_smile_02",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_01_03_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(...But...)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-normal04-tilthead",
          "FacialName": "face_sad_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_01_04_20",
