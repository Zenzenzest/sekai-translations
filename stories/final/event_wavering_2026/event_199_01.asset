    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 294
        }
      ],
      "WindowDisplayName": "Kanade",
      "Body": "...Yeah.",
      "TalkTention": 0,
      "LipSync": 0,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 294
        }
      ],
      "WindowDisplayName": "Kanade",
      "Body": "I've been trying to think of a song that captures the warmth of Mafuyu's mother to save her, but... I'm a bit lost on the direction.",
      "TalkTention": 0,
      "LipSync": 0,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 294,
          "MotionName": "w-kanade16-tilthead",
          "FacialName": "face_sad_02",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 294
        }
      ],
      "WindowDisplayName": "Kanade",
      "Body": "So, I feel bad for Mafuyu, but... I need a little time to figure out what kind of song to make.",
      "TalkTention": 0,
      "LipSync": 0,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 294,
          "MotionName": "w-normal15-shy",
          "FacialName": "face_sad_01",
          "TimingSyncValue": 0.0
