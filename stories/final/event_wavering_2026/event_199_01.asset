    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(Enanan is seriously amazing.)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
