      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(Ever since I heard she was aiming for Toubi, it's like her art has become more vibrant...)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
