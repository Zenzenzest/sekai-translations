    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "I see... So that's why the song had a different vibe this time.",
      "TalkTention": 0,
      "LipSync": 1,
