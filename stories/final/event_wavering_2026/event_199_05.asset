    {
      "TalkCharacters": [
        {
          "Character2dId": 309
        }
      ],
      "WindowDisplayName": "Rin",
      "Body": "What kind of outfit are you going to make?",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 309,
          "VoiceId": "voice_ev_night_25_05_54_22_night",
