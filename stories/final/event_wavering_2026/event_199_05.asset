      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 272
        }
      ],
      "WindowDisplayName": "Mizuki's Sister",
      "Body": "'What's wrong?'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 272,
          "MotionName": "s-common-tilthead01",
