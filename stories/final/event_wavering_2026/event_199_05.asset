      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 296
        }
      ],
      "WindowDisplayName": "Ena",
      "Body": "Oh, that's cute. But yeah, making it looks like it'd be a pain...",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 296,
          "MotionName": "w-cute12-nod",
