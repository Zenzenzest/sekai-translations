        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(Even if the time comes when I have to leave Niigo someday...)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
