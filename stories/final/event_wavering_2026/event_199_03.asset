  "TalkData": [
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Instructor",
      "Body": "Thank you all for gathering for the Designer Course workshop.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_03_01_9999",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Instructor",
      "Body": "Today, you will be creating fashion illustrations using collage design. Let's have fun making them together!",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_03_02_9999",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "Yes!",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_03_03_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 1,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(I'm so lucky I get to experience designing at a workshop! I'm gonna make the cutest outfit ever♪)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-normal01-tilthead",
          "FacialName": "face_smile_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_03_04_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Instructor",
      "Body": "Now, let me briefly explain the process. Has everyone received the paper handed out?",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_03_05_9999",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(Paper... Oh, the one with the human silhouette drawn on it?)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-normal01-tilthead",
          "FacialName": "face_smallmouth_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_03_06_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Instructor",
      "Body": "Looks like everyone has it. The silhouette drawn there represents the model who will be wearing our clothes.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_03_07_9999",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Instructor",
      "Body": "Normally, designers themselves would pose and draw the figure to match the fashion they are designing, but today, we have prepared this for you.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_03_08_9999",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Participant A",
      "Body": "You have to make these yourself, too... I wonder if I can draw it well.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_03_09_9999",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Instructor",
      "Body": "You'll get used to it. If you're not confident, they are also sold, so don't worry.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_03_10_9999",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "(I see! It's true that drawing the pose yourself makes it easier to create exactly what you imagine, but this seems convenient when you're in a hurry.)",
      "TalkTention": 0,
      "LipSync": 2,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 297,
          "MotionName": "w-adult01-nod",
          "FacialName": "face_smile_01",
          "TimingSyncValue": 0.0
        }
      ],
      "Voices": [
        {
          "Character2dId": 297,
          "VoiceId": "voice_ev_night_25_03_11_20",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Instructor",
      "Body": "Now, please feel free to cut out the magazines, illustrations, and fabric materials here as you like, paste them onto your paper, and create your very own outfit.",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
          "Character2dId": 0,
          "VoiceId": "voice_ev_night_25_03_12_9999",
          "Volume": 1.0
        }
      ],
      "Speed": 0.0,
      "FontSize": 0,
      "WhenFinishCloseWindow": 0,
      "RequirePlayEffect": 0,
      "EffectReferenceIdx": 0,
      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 0
        }
      ],
      "WindowDisplayName": "Instructor",
      "Body": "For example... you could cut out the outfit worn by a model in this magazine and combine it with the skirt from this illustration. Feel free to use your imagination.",
      "TalkTention": 0,
