    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "Let's see... ah! The skirt on this page is so cute! It might look good if I combine it with the big ribbon from this other magazine...!",
