        {
          "Character2dId": 303
        }
      ],
      "WindowDisplayName": "Miku",
      "Body": "'...It's amazing. There are so many different kinds of clothes.'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [],
      "Voices": [
        {
