    {
      "TalkCharacters": [
        {
          "Character2dId": 297
        }
      ],
      "WindowDisplayName": "Mizuki",
      "Body": "Ah! That dress over there actually won an award in a contest! The hat displayed with it is super stylish, too~",
      "TalkTention": 0,
