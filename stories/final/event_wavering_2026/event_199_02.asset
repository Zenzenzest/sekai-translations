      "RequirePlaySound": 0,
      "SoundReferenceIdx": 0,
      "TargetValueScale": 0.0
    },
    {
      "TalkCharacters": [
        {
          "Character2dId": 303
        }
      ],
      "WindowDisplayName": "Miku",
      "Body": "'...It looks kind of tattered.'",
      "TalkTention": 0,
      "LipSync": 1,
      "MotionChangeFrom": 1,
      "Motions": [
        {
          "Character2dId": 303,
          "MotionName": "w-normal15-tilthead",
